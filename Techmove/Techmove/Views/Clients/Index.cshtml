@model IEnumerable<ClientViewModel>
@{
    ViewData["Title"] = "Clients";
}

<div class="glms-page-header">
    <div>
        <h1 class="h3 mb-0">Client Management</h1>
        <p class="glms-page-subtitle">Manage client records and linked accounts</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Add Client</a>
</div>

<div class="panel-card">
    @if (TempData["ClientError"] is string error)
    {
        <div class="alert alert-danger">@error</div>
    }

    @if (!Model.Any())
    {
        <p class="mb-0">No clients yet. Add your first client to start building live data.</p>
    }
    else
    {
    <table class="table glms-table mb-0">
        <thead>
            <tr>
                <th>Linked Username</th>
                <th>Client Name</th>
                <th>Contact Details</th>
                <th>Region</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var client in Model)
        {
            <tr>
                <td>@(string.IsNullOrWhiteSpace(client.AccountUsername) ? "-" : client.AccountUsername)</td>
                <td>@client.Name</td>
                <td>@client.ContactDetails</td>
                <td>@client.Region</td>
                <td class="text-end">
                    <div class="btn-group btn-group-sm" role="group">
                        <a class="btn btn-outline-primary" asp-action="Details" asp-route-id="@client.Id">Details</a>
                        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@client.Id">Edit</a>
                        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@client.Id">Delete</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
    }
</div>
