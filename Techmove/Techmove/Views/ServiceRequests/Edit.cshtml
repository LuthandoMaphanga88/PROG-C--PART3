@model ServiceRequestViewModel
@{
    ViewData["Title"] = "Edit Service Request";
    var contracts = ViewBag.Contracts as IReadOnlyList<ContractViewModel> ?? [];
}

<div class="panel-card">
    <h1 class="h3 mb-3">Edit Service Request</h1>
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ContractRef" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="ContractId" class="form-label">Contract</label>
                <select asp-for="ContractId" class="form-select" id="contractSelect">
                    <option value="">Select contract</option>
                    @foreach (var contract in contracts)
                    {
                        <option value="@contract.Id" data-status="@contract.Status">CT-@contract.Id - @contract.ClientName (@contract.Status)</option>
                    }
                </select>
                <small id="contractMessage" class="text-danger d-none">This contract is not valid for service requests.</small>
            </div>
            <div class="col-md-6">
                <label asp-for="Status" class="form-label">Request Status</label>
                <select asp-for="Status" class="form-select">
                    <option>Open</option>
                    <option>Pending Approval</option>
                    <option>In Progress</option>
                    <option>Closed</option>
                </select>
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="col-md-6">
                <label asp-for="CostUsd" class="form-label">Cost (USD)</label>
                <input asp-for="CostUsd" type="number" class="form-control" min="0" step="0.01" />
            </div>
            <div class="col-md-6">
                <label asp-for="CostZar" class="form-label">Cost (ZAR)</label>
                <input asp-for="CostZar" type="number" class="form-control" min="0" step="0.01" />
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button class="btn btn-primary" id="submitBtn" type="submit">Save Changes</button>
            <a class="btn btn-outline-primary" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function validateContract() {
            const contractSelect = document.getElementById("contractSelect");
            const selectedOption = contractSelect.options[contractSelect.selectedIndex];
            const contractStatus = selectedOption?.dataset?.status || "";
            const isValid = contractStatus === "Active";
            document.getElementById("submitBtn").disabled = !isValid;
            document.getElementById("contractMessage").classList.toggle("d-none", isValid || !contractStatus);
        }

        document.getElementById("contractSelect").addEventListener("change", validateContract);
        validateContract();
    </script>
}
