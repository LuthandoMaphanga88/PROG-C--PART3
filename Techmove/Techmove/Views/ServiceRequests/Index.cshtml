@model ServiceRequestsIndexViewModel
@{
    ViewData["Title"] = "Service Requests";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Service Request Processing</h1>
    <a class="btn btn-primary" asp-action="Create">Raise Request</a>
</div>

<div class="panel-card">
    @if (TempData["ServiceRequestError"] is string error)
    {
        <div class="alert alert-danger">@error</div>
    }

    @if (!Model.Requests.Any())
    {
        <p class="mb-0">No service requests yet. Raise requests from your active contracts.</p>
    }
    else
    {
    <table class="table glms-table mb-0">
        <thead>
            <tr>
                <th>Request ID</th>
                <th>Contract</th>
                <th>Description</th>
                <th>Cost (USD)</th>
                <th>Cost (ZAR)</th>
                <th>Cost (EUR)</th>
                <th>Cost (GBP)</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var request in Model.Requests)
        {
            <tr>
                <td>SR-@request.Id</td>
                <td>@request.ContractRef</td>
                <td>@request.Description</td>
                <td>$@request.CostUsd.ToString("N2")</td>
                <td>R @request.CostZar.ToString("N2")</td>
                <td>€@((request.CostUsd * Model.EurRate).ToString("N2"))</td>
                <td>£@((request.CostUsd * Model.GbpRate).ToString("N2"))</td>
                <td>@request.Status</td>
                <td class="text-end">
                    <div class="btn-group btn-group-sm" role="group">
                        <a class="btn btn-outline-primary" asp-action="Details" asp-route-id="@request.Id">Details</a>
                        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@request.Id">Edit</a>
                        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@request.Id">Delete</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
    }
</div>
