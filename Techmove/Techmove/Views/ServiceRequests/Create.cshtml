@model ServiceRequestViewModel
@{
    ViewData["Title"] = "Raise Service Request";
    var contracts = ViewBag.Contracts as IReadOnlyList<ContractViewModel> ?? [];
}

<div class="panel-card">
    <h1 class="h3 mb-3">Raise Service Request</h1>
    @if (!contracts.Any())
    {
        <div class="alert alert-warning mb-3">Create a contract before raising a service request.</div>
    }
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
        <div class="alert alert-info">
            Requests can only be submitted for contracts with an <strong>Active</strong> status.
        </div>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Contract</label>
                <select class="form-select" id="contractSelect" name="contractId">
                    <option value="">Select contract</option>
                    @foreach (var contract in contracts)
                    {
                        <option value="@contract.Id" data-status="@contract.Status">CT-@contract.Id - @contract.ClientName (@contract.Status)</option>
                    }
                </select>
                <small id="contractMessage" class="text-danger d-none">This contract is not valid for new requests.</small>
            </div>
            <div class="col-md-6">
                <label class="form-label">Request Status</label>
                <select asp-for="Status" class="form-select">
                    <option>Open</option>
                    <option>Pending Approval</option>
                    <option>In Progress</option>
                    <option>Closed</option>
                </select>
            </div>
            <div class="col-12">
                <label class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Describe the logistics service request"></textarea>
            </div>
            <div class="col-md-4">
                <label class="form-label">Cost (USD)</label>
                <input asp-for="CostUsd" type="number" class="form-control" id="usdAmount" placeholder="0.00" min="0" step="0.01" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Live USD/ZAR Rate</label>
                <input type="text" class="form-control" id="zarRate" readonly placeholder="Fetching..." />
            </div>
            <div class="col-md-4">
                <label class="form-label">Cost (ZAR)</label>
                <input asp-for="CostZar" type="text" class="form-control" id="zarAmount" readonly placeholder="0.00" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Live USD/EUR Rate</label>
                <input type="text" class="form-control" id="eurRate" readonly placeholder="Fetching..." />
            </div>
            <div class="col-md-4">
                <label class="form-label">Cost (EUR)</label>
                <input type="text" class="form-control" id="eurAmount" readonly placeholder="0.00" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Live USD/GBP Rate</label>
                <input type="text" class="form-control" id="gbpRate" readonly placeholder="Fetching..." />
            </div>
            <div class="col-md-4">
                <label class="form-label">Cost (GBP)</label>
                <input type="text" class="form-control" id="gbpAmount" readonly placeholder="0.00" />
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button class="btn btn-primary" id="submitBtn" type="submit" disabled="@(!contracts.Any())">Save Request</button>
            <a class="btn btn-outline-primary" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
    let rates = {
        ZAR: 0,
        EUR: 0,
        GBP: 0
    };

    async function fetchUsdRates() {
        try {
            const response = await fetch("/api/exchange-rates?baseCurrency=USD&targets=ZAR,EUR,GBP");
            if (!response.ok) {
                throw new Error("Failed to fetch rates.");
            }

            const data = await response.json();
            rates.ZAR = data?.rates?.ZAR ?? 0;
            rates.EUR = data?.rates?.EUR ?? 0;
            rates.GBP = data?.rates?.GBP ?? 0;

            document.getElementById("zarRate").value = rates.ZAR ? rates.ZAR.toFixed(4) : "Unavailable";
            document.getElementById("eurRate").value = rates.EUR ? rates.EUR.toFixed(4) : "Unavailable";
            document.getElementById("gbpRate").value = rates.GBP ? rates.GBP.toFixed(4) : "Unavailable";
            calculateConvertedAmounts();
        } catch {
            document.getElementById("zarRate").value = "Unavailable";
            document.getElementById("eurRate").value = "Unavailable";
            document.getElementById("gbpRate").value = "Unavailable";
        }
    }

    function calculateConvertedAmounts() {
        const usdAmount = parseFloat(document.getElementById("usdAmount").value || "0");
        const zarAmount = usdAmount * rates.ZAR;
        const eurAmount = usdAmount * rates.EUR;
        const gbpAmount = usdAmount * rates.GBP;

        document.getElementById("zarAmount").value = zarAmount ? zarAmount.toFixed(2) : "0.00";
        document.getElementById("eurAmount").value = eurAmount ? eurAmount.toFixed(2) : "0.00";
        document.getElementById("gbpAmount").value = gbpAmount ? gbpAmount.toFixed(2) : "0.00";
    }

    function validateContract() {
        const contractSelect = document.getElementById("contractSelect");
        const selectedOption = contractSelect.options[contractSelect.selectedIndex];
        const contractStatus = selectedOption?.dataset?.status || "";
        const isActive = contractStatus === "Active";
        document.getElementById("submitBtn").disabled = !isActive;
        document.getElementById("contractMessage").classList.toggle("d-none", isActive || !contractStatus);
    }

    document.getElementById("usdAmount").addEventListener("input", calculateConvertedAmounts);
    document.getElementById("contractSelect").addEventListener("change", validateContract);

    fetchUsdRates();
    validateContract();
</script>
}
