@model ContractViewModel
@{
    ViewData["Title"] = "Edit Contract";
    var clients = ViewBag.Clients as IReadOnlyList<ClientViewModel> ?? [];
}

<div class="panel-card">
    <h1 class="h3 mb-3">Edit Contract</h1>
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="AgreementFileName" />
        <input type="hidden" asp-for="ClientReturnedAgreementFileName" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Client</label>
                <select asp-for="ClientName" class="form-select">
                    <option value="">Select client</option>
                    @foreach (var client in clients)
                    {
                        <option value="@client.Name">@client.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="ServiceLevel" class="form-label">Service Level</label>
                <select asp-for="ServiceLevel" class="form-select">
                    <option>Gold SLA</option>
                    <option>Silver SLA</option>
                    <option>Bronze SLA</option>
                </select>
            </div>
            <div class="col-md-4">
                <label asp-for="StartDate" class="form-label">Start Date</label>
                <input asp-for="StartDate" type="date" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="EndDate" class="form-label">End Date</label>
                <input asp-for="EndDate" type="date" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="Status" class="form-label">Status</label>
                <select asp-for="Status" class="form-select">
                    <option>Draft</option>
                    <option>Active</option>
                    <option>Expired</option>
                    <option>On Hold</option>
                </select>
            </div>
            <div class="col-12">
                <label class="form-label">Replace Signed Agreement (PDF)</label>
                <input type="file" class="form-control" accept=".pdf" name="signedAgreement" />
                @if (!string.IsNullOrWhiteSpace(Model.AgreementFileName))
                {
                    <small class="text-muted">Current file: @Model.AgreementFileName</small>
                }
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button class="btn btn-primary" type="submit">Save Changes</button>
            <a class="btn btn-outline-primary" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
