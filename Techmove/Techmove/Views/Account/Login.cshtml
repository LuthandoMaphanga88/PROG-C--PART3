@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="glms-login-shell">
    <div class="panel-card glms-login-card">
        <h1 class="h4 glms-login-heading">Sign in to GLMS</h1>
        <p class="text-muted glms-login-sub">Use your Admin or Client credentials to access the portal.</p>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label"></label>
                    <input asp-for="Username" class="form-control" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <button class="btn btn-primary w-100" type="submit">Login</button>
            </form>

            <hr />
            <small class="text-muted">
                Demo users:<br />
                Admin: admin / admin123<br />
                Client: client / client123
            </small>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
